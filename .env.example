# OpenAI — solo para funciones server-side (Netlify)
OPENAI_API_KEY=sk-...

# Turso DB
TURSO_URL=https://...
TURSO_TOKEN=eyJ...

# Admin panel
ADMIN_SETUP_KEY=...        # Clave de primer arranque (solo cuando admin_users está vacío)
ADMIN_JWT_SECRET=...       # Secreto para firmar JWTs de sesión — generar con: openssl rand -hex 32

# Cloudinary (server-side only)
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Cloudinary cloud name exposed to browser (read-only, no secret)
VITE_CLOUDINARY_CLOUD_NAME=...

# Google Search Console
GSC_CLIENT_ID=...
GSC_CLIENT_SECRET=...
GSC_REFRESH_TOKEN=...
GOOGLE_SITE_URL=https://...
